# WIL Management System - Environment Configuration
# Copy this file to .env and update the values

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-super-secret-key-change-in-production

# Database Configuration
# For SQLite (development):
DATABASE_URL=sqlite:///database/wil_system.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost/wil_system

# Email Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@wil-system.ac.za

# External API Keys (Optional)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# SMS_API_KEY=your-sms-api-key

# Security Settings
WTF_CSRF_SECRET_KEY=your-csrf-secret-key

# Application Settings
MAX_APPLICATIONS_PER_STUDENT=10
DEADLINE_REMINDER_DAYS=3
EMAIL_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=false

# Maintenance Mode
MAINTENANCE_MODE=false